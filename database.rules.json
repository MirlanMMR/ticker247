{
  "rules": {
    // Новости — публичное чтение, запись только с сервера (закрыта для всех клиентов)
    "news": {
      ".read": true,
      ".write": false
    },

    // Избранное пользователя — только сам пользователь
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // Всё остальное — закрыто
    ".read": false,
    ".write": false
  }
}
